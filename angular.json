{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "blueboot-chat": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": { "style": "scss" }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "index": "src/index.html",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "outputPath": "dist/blueboot-chat/browser",
            "assets": [
              { "glob": "**/*", "input": "public" },
              "src/assets"
            ],
            "styles": ["src/styles.scss"]
          },
          "configurations": {
            "production": {
              "optimization": {
                "scripts": true,
                "styles": { "minify": true, "inlineCritical": false },
                "fonts": false
              },
              "extractLicenses": true,
              "sourceMap": false,
              "outputHashing": "none"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "local": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.local.ts"
                }
              ]
            },
            "elements": {
              "browser": "src/elements.ts",
              "index": false,
              "polyfills": ["zone.js"],
              "tsConfig": "tsconfig.app.json",
              "inlineStyleLanguage": "scss",
              "outputPath": "dist/blueboot-chat/browser",
              "assets": [
                { "glob": "**/*", "input": "public" },
                "src/assets"
              ],
              "styles": ["src/styles.scss"]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "blueboot-chat:build:development"
          },
          "configurations": {
            "production": { "buildTarget": "blueboot-chat:build:production" },
            "development": { "buildTarget": "blueboot-chat:build:development" },
            "local": { "buildTarget": "blueboot-chat:build:local" },
            "elements": { "buildTarget": "blueboot-chat:build:elements" }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": { "builder": "@angular/build:extract-i18n" },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              { "glob": "**/*", "input": "public" },
              "src/assets"
            ],
            "styles": ["src/styles.scss"]
          }
        }
      }
    }
  },
  "cli": { "analytics": false }
}
